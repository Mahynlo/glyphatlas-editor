{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GlyphAtlas Editor",
  "version": "0.1.1",
  "identifier": "com.malco.pdfeditor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GlyphAtlas Editor",
        "width": 800,
        "height": 600,
        "additionalBrowserArgs": "--enable-unsafe-webgpu"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../public/models/paddle/*": "./models/paddle/"
    },
    "fileAssociations": [
      {
        "name": "PDF Document",
        "ext": [
          "pdf"
        ],
        "mimeType": "application/pdf",
        "description": "Portable Document Format",
        "role": "Editor"
      }
    ]
  }
}